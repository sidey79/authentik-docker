# Generate with: openssl rand -base64 60
AUTHENTIK_SECRET_KEY=replace-with-long-random-secret

# Set to false if you do not want telemetry/error reporting
AUTHENTIK_ERROR_REPORTING__ENABLED=true

AUTHENTIK_POSTGRESQL__NAME=authentik
AUTHENTIK_POSTGRESQL__USER=authentik
AUTHENTIK_POSTGRESQL__PASSWORD=replace-with-strong-password

# SMTP settings (for example with https://github.com/sidey79/smtp-relay-docker)
AUTHENTIK_EMAIL__HOST=smtp-relay
AUTHENTIK_EMAIL__PORT=25
AUTHENTIK_EMAIL__USERNAME=
AUTHENTIK_EMAIL__PASSWORD=
AUTHENTIK_EMAIL__USE_TLS=false
